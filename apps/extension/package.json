{
  "name": "@clickspex/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --write . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@clickspex/core": "workspace:*",
    "@clickspex/shared": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0",
    "@clickspex/adapters": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@clickspex/config": "workspace:*",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^6.4.3",
    "vitest": "^3.0.0"
  }
}
