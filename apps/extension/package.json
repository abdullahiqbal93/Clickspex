    "react-dom": "^18.3.0",
    "zustand": "^5.0.0",
    "@ui-devtools/adapters": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@ui-devtools/config": "workspace:*",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0"
  }
