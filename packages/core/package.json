{
  "name": "@clickspex/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./project": {
      "types": "./src/projectDetection.ts",
      "import": "./dist/projectDetection.js"
    },
    "./styleDiff": {
      "types": "./src/styleDiff.ts",
      "import": "./dist/styleDiff.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --write . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@clickspex/shared": "workspace:*"
  },
  "devDependencies": {
    "@clickspex/config": "workspace:*",
    "vitest": "^4.1.10"
  }
}
